    family-names: "Badang"
    alias: "YG-paaleee"
repository-code: "https://github.com/YG-paaleee/bci-dataset-cards"
url: "https://github.com/YG-paaleee/bci-dataset-cards"
license: MIT
version: "0.3.1"
date-released: "2026-06-21"
keywords:
  - EEG
  - BCI
  - brain-computer interface
  - dataset card
  - reproducibility
  - leakage
  - MOABB
  - EEGDash
